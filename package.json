{
  "name": "visit-tracker",
  "version": "2.0.0",
  "description": "訪問看護ステーション 訪問件数管理Webアプリ",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node test-leave.js && node test-admin-init.js && node test-api.js && node test-regression.js",
    "test:unit": "node test-leave.js && node test-admin-init.js",
    "test:api": "node test-api.js",
    "lint": "eslint server.js lib/ routes/ && for f in public/js/admin-*.js; do node -c \"$f\" || exit 1; done && echo '✅ Lint OK'",
    "security-check": "node scripts/security-check.js"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "cookie-session": "^2.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "googleapis": "^140.0.0",
    "helmet": "^8.1.0",
    "holiday-jp": "^1.0.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "write-file-atomic": "^7.0.1",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "supertest": "^7.2.2"
  }
}
