# ─── 認証（必須）
SESSION_SECRET=change_this_to_a_long_random_string

# ─── Google Sheets（必須）
SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"xxx@xxx.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── サーバー設定
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DATA_DIR=./data

# ─── 管理者初期設定（カンマ区切りでスタッフIDを指定）
INITIAL_ADMIN_STAFF_IDS=
# 後方互換用（単数版）: INITIAL_ADMIN_STAFF_ID=

# ─── メール通知（任意）
MAIL_FROM=
MAIL_APP_PASSWORD=

# ─── ビジネスルール（変更する場合のみ設定。デフォルト値はコメント参照）
# 締め期間開始日（デフォルト: 16日）
BILLING_DAY=16
# インセンティブ単価デフォルト（デフォルト: 看護4000円/リハ500円）
INCENTIVE_NURSE_RATE=4000
INCENTIVE_REHAB_RATE=500
# 待機手当料金（デフォルト: 祝日・日曜10000円/土曜5000円/平日2000円）
STANDBY_FEE_HOLIDAY=10000
STANDBY_FEE_SUNDAY=10000
STANDBY_FEE_SATURDAY=5000
STANDBY_FEE_WEEKDAY=2000

# ─── 監査ログ保存先（任意。省略時はDATA_DIR内に保存）
AUDIT_LOG_NDJSON_PATH=
